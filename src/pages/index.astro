<script is:inline>
  // ── Desktop download cards — visas bara om det finns en publik release ──
  (function() {
    var REPO = "ErikAxelsson/homeplanning";
    var section = document.getElementById("ladda-ner");
    var container = document.getElementById("download-cards");
    var macNote = document.getElementById("download-macos-note");
    if (!section || !container) return;

    var PLATFORMS = [
      {
        label: "Windows",
        ext: ".msi",
        meta: "Installationsfil för Windows",
        icon: '<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>',
      },
      {
        label: "Linux",
        ext: ".AppImage",
        meta: "Kör direkt, ingen installation",
        icon: '<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M9.5 9.5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5c0 1.8-2.5 4.5-2.5 4.5s-2.5-2.7-2.5-4.5z"/><circle cx="12" cy="17.5" r=".75" fill="currentColor" stroke="none"/></svg>',
      },
    ];

    fetch("https://api.github.com/repos/" + REPO + "/releases/latest")
      .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
      .then(function(release) {
        var assets = release.assets || [];
        var found = 0;

        PLATFORMS.forEach(function(p) {
          var asset = assets.find(function(a) { return a.name.toLowerCase().endsWith(p.ext); });
          if (!asset) return;
          found++;
          var size = asset.size ? (asset.size / 1048576).toFixed(0) + " MB" : "";
          var card = document.createElement("a");
          card.className = "download-card";
          card.href = asset.browser_download_url;
          card.innerHTML =
            '<span class="download-card-icon">' + p.icon + '</span>' +
            '<span>' +
              '<div class="download-card-title">Ladda ner för ' + p.label + '</div>' +
              '<div class="download-card-meta">' + p.meta + (size ? " &middot; " + size : "") + '</div>' +
            '</span>';
          container.appendChild(card);
        });

        if (found > 0) {
          section.style.display = "";
          if (macNote) macNote.style.display = "";
        }
      })
      .catch(function() { /* ingen release ännu — sektionen förblir dold */ });
  })();

  var WAITLIST_URL = "https://app.nidero.se/waitlist";

  function submitWaitlist(event, source) {
    event.preventDefault();
    var form = event.currentTarget;
    var input = form.querySelector('input[type=email]');
    var button = form.querySelector('button');
    if (!input || !input.value) return false;

    button.disabled = true;
    button.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation:spin .7s linear infinite"><path d="M12 2a10 10 0 1 0 10 10"/></svg>';

    fetch(WAITLIST_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email: input.value, source: source }),
    })
      .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
      .then(function() {
        form.classList.add("success");
        button.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg> Klart!';
        input.disabled = true;
      })
      .catch(function() {
        button.disabled = false;
        button.textContent = "Försök igen";
      });

    return false;
  }
</script>

