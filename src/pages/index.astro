---
const features = [
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
    title: "Månadsbudget",
    desc: "Registrera inkomster och utgifter per person. Dela kostnader med slider, följ sparkvoten månad för månad.",
  },
  {
    icon: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
    title: "Lån & räntor",
    desc: "Samla alla bolån på ett ställe. Räntescenariokalkylator med live-data från Riksbanken.",
  },
  {
    icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
    title: "Balansräkning",
    desc: "Nettovärde, tillgångsfördelning och skuldsättning — alltid uppdaterat, alltid rätt.",
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    title: "Sparmål",
    desc: "Sätt upp mål — kontantinsats, bil, pension. Få prognoser och fondrekommendationer anpassade till din tidshorisont.",
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: "Familjevy",
    desc: "Flera familjemedlemmar, gemensamma och individuella konton. Barn och vuxna hanteras separat.",
  },
  {
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
    title: "AI-analys",
    desc: "Låt AI gå igenom er ekonomi och ge konkreta råd — sparkvot, räntekänslighet, optimeringsmöjligheter.",
  },
];
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ordo — Ordning på familjens ekonomi</title>
    <meta name="description" content="Ordo samlar familjens hela ekonomi på ett ställe. Budget, sparande, lån, balansräkning och AI-analys — byggt för svenska familjer." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- NAV -->
    <nav>
      <div class="container nav-inner">
        <a href="/" class="logo">
          <svg viewBox="0 0 64 64" width="28" height="28" fill="none" aria-hidden="true" class="logo-icon">
            <rect x="9.75"  y="44" width="6.5" height="12" rx="3.25" fill="currentColor" opacity="0.45"/>
            <rect x="19.25" y="38" width="6.5" height="18" rx="3.25" fill="currentColor" opacity="0.60"/>
            <rect x="28.75" y="31" width="6.5" height="25" rx="3.25" fill="currentColor" opacity="0.75"/>
            <rect x="38.25" y="24" width="6.5" height="32" rx="3.25" fill="currentColor" opacity="0.90"/>
            <rect x="47.75" y="19" width="6.5" height="37" rx="3.25" fill="var(--brand)"/>
          </svg>
          Ordo
        </a>
        <a href="https://homeplanning-staging.up.railway.app" class="btn-outline" target="_blank">Logga in</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-badge">Byggt för svenska familjer</div>
        <h1>Ordning på<br /><em>familjens ekonomi</em></h1>
        <p class="hero-sub">
          Ordo samlar budget, sparande, lån och tillgångar på ett ställe.
          Så att ni alltid vet var ni står — och vart ni är på väg.
        </p>
        <div class="hero-cta">
          <a href="#waitlist" class="btn-primary">Kom med på väntelistan</a>
          <a href="#features" class="btn-ghost">Se vad Ordo kan →</a>
        </div>

        <!-- App mockup -->
        <div class="mockup">
          <div class="mockup-bar">
            <span></span><span></span><span></span>
          </div>
          <div class="mockup-content">

            <!-- Top hero row -->
            <div class="mockup-hero-row">
              <div class="mockup-hero-stat">
                <div class="mockup-label">NETTOVÄRDE</div>
                <div class="mockup-hero-value">2 847 300 kr</div>
              </div>
              <div class="mockup-hero-badges">
                <span class="mockup-badge green">↑ 14 200 kr denna månad</span>
                <span class="mockup-badge neutral">Sparkvot 19 %</span>
              </div>
            </div>

            <!-- Two cards -->
            <div class="mockup-card-row">
              <div class="mockup-card">
                <div class="mockup-card-top">
                  <span class="mockup-label">BUDGET MAJ</span>
                  <span class="mockup-chip">På spår</span>
                </div>
                <div class="mockup-card-body">
                  <div class="mockup-row">
                    <span class="mockup-row-label">Inkomst</span>
                    <span class="mockup-row-val">74 500 kr</span>
                  </div>
                  <div class="mockup-row">
                    <span class="mockup-row-label">Utgifter</span>
                    <span class="mockup-row-val muted">–53 800 kr</span>
                  </div>
                  <div class="mockup-divider"></div>
                  <div class="mockup-row">
                    <span class="mockup-row-label bold">Sparande</span>
                    <span class="mockup-row-val green bold">20 700 kr</span>
                  </div>
                </div>
              </div>
              <div class="mockup-card">
                <div class="mockup-card-top">
                  <span class="mockup-label">BOLÅN</span>
                  <span class="mockup-chip" style="background:color-mix(in srgb,#f59e0b 15%,transparent);color:#d97706;">Binder om snart</span>
                </div>
                <div class="mockup-card-body">
                  <div class="mockup-row">
                    <span class="mockup-row-label">Skuld</span>
                    <span class="mockup-row-val">2 950 000 kr</span>
                  </div>
                  <div class="mockup-row">
                    <span class="mockup-row-label">Snittränta</span>
                    <span class="mockup-row-val muted">3,85 %</span>
                  </div>
                  <div class="mockup-divider"></div>
                  <div class="mockup-row">
                    <span class="mockup-row-label bold">Räntekostnad</span>
                    <span class="mockup-row-val bold">9 469 kr/mån</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Mini bar chart -->
            <div class="mockup-chart-row">
              <div class="mockup-label" style="margin-bottom: 8px;">NETTOVÄRDE — 6 MÅNADER</div>
              <div class="mockup-bars">
                {[42, 35, 55, 61, 50, 74].map((h, i) => (
                  <div class="mockup-bar-col">
                    <div class="mockup-bar-fill" style={`height:${h}px; opacity:${0.35 + i*0.12}`}></div>
                    <span class="mockup-bar-label">{["Nov","Dec","Jan","Feb","Mar","Apr"][i]}</span>
                  </div>
                ))}
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="problem">
      <div class="container problem-inner">
        <p class="problem-text">
          De flesta familjer hanterar ekonomin i spridda Exceldokument, separata bankapper och huvudet.
          Det funkar — tills det inte funkar.
        </p>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features" id="features">
      <div class="container">
        <div class="section-header">
          <div class="section-tag">Funktioner</div>
          <h2>Allt ni behöver.<br />Inget ni inte behöver.</h2>
          <p class="section-sub">Ordo är byggt kring hur svenska familjer faktiskt tänker på pengar — inte hur banker vill att ni ska tänka.</p>
        </div>
        <div class="features-grid">
          {features.map(f => (
            <div class="feature-card">
              <div class="feature-icon">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
              </div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MOBILE SECTION -->
    <section class="mobile-section">
      <div class="container mobile-inner">
        <div class="mobile-text">
          <div class="section-tag">Alltid med dig</div>
          <h2>Hela ekonomin i fickan — med smarta notiser</h2>
          <p>
            Ordo skickar push-notiser när det händer något du bör känna till. Ingen anledning att logga in varje dag — Ordo hör av sig när det är dags.
          </p>
          <ul class="mobile-list">
            <li>
              <div class="mobile-list-icon">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              </div>
              <span>Påminnelse att lägga in lönen — automatiskt dag 21–28 varje månad</span>
            </li>
            <li>
              <div class="mobile-list-icon">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Bekräftelse när bådas löner är inlagda och månaden är klar</span>
            </li>
            <li>
              <div class="mobile-list-icon">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <span>Påminnelse om obestyrkta överföringar mellan familjemedlemmar</span>
            </li>
            <li>
              <div class="mobile-list-icon">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <span>Egna schemalagda notiser — valfritt innehåll och tidpunkt</span>
            </li>
          </ul>
        </div>

        <!-- Phone mockup -->
        <div class="phone-wrap">
          <div class="phone">
            <div class="phone-notch"></div>
            <div class="phone-screen">
              <!-- Status bar -->
              <div class="phone-statusbar">
                <span>09:41</span>
                <div class="phone-statusbar-icons">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M1.5 8.5C5.5 4.5 18.5 4.5 22.5 8.5L20 11c-3-3-13-3-16 0L1.5 8.5z"/><path d="M5 12c1.9-1.9 13-1.9 14 0l-2.5 2.5c-1-1-8-1-9 0L5 12z"/><path d="M9 15.5c.9-.9 6-.9 6 0L12 18.5 9 15.5z"/></svg>
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><rect x="2" y="7" width="18" height="11" rx="2"/><path d="M22 11v3"/></svg>
                </div>
              </div>

              <!-- Lock screen notifications -->
              <div class="phone-lock">
                <div class="phone-time">09:41</div>
                <div class="phone-date">Lördag 24 maj</div>

                <div class="phone-notifs">
                  <div class="phone-notif">
                    <div class="phone-notif-app">
                      <svg viewBox="0 0 64 64" width="16" height="16" fill="none">
                        <rect x="9.75"  y="44" width="6.5" height="12" rx="3.25" fill="white" opacity="0.5"/>
                        <rect x="19.25" y="38" width="6.5" height="18" rx="3.25" fill="white" opacity="0.65"/>
                        <rect x="28.75" y="31" width="6.5" height="25" rx="3.25" fill="white" opacity="0.8"/>
                        <rect x="38.25" y="24" width="6.5" height="32" rx="3.25" fill="white" opacity="0.9"/>
                        <rect x="47.75" y="19" width="6.5" height="37" rx="3.25" fill="white"/>
                      </svg>
                      <span>Ordo</span>
                      <span class="phone-notif-time">nu</span>
                    </div>
                    <div class="phone-notif-title">Månadens beräkning klar! ✅</div>
                    <div class="phone-notif-body">Bådas löner för maj 2025 är inlagda.</div>
                  </div>
                  <div class="phone-notif">
                    <div class="phone-notif-app">
                      <svg viewBox="0 0 64 64" width="16" height="16" fill="none">
                        <rect x="9.75"  y="44" width="6.5" height="12" rx="3.25" fill="white" opacity="0.5"/>
                        <rect x="19.25" y="38" width="6.5" height="18" rx="3.25" fill="white" opacity="0.65"/>
                        <rect x="28.75" y="31" width="6.5" height="25" rx="3.25" fill="white" opacity="0.8"/>
                        <rect x="38.25" y="24" width="6.5" height="32" rx="3.25" fill="white" opacity="0.9"/>
                        <rect x="47.75" y="19" width="6.5" height="37" rx="3.25" fill="white"/>
                      </svg>
                      <span>Ordo</span>
                      <span class="phone-notif-time">igår</span>
                    </div>
                    <div class="phone-notif-title">Kom ihåg att föra över! 💸</div>
                    <div class="phone-notif-body">Du har inte bekräftat din överföring för april 2025 än.</div>
                  </div>
                  <div class="phone-notif muted">
                    <div class="phone-notif-app">
                      <svg viewBox="0 0 64 64" width="16" height="16" fill="none">
                        <rect x="9.75"  y="44" width="6.5" height="12" rx="3.25" fill="white" opacity="0.5"/>
                        <rect x="19.25" y="38" width="6.5" height="18" rx="3.25" fill="white" opacity="0.65"/>
                        <rect x="28.75" y="31" width="6.5" height="25" rx="3.25" fill="white" opacity="0.8"/>
                        <rect x="38.25" y="24" width="6.5" height="32" rx="3.25" fill="white" opacity="0.9"/>
                        <rect x="47.75" y="19" width="6.5" height="37" rx="3.25" fill="white"/>
                      </svg>
                      <span>Ordo</span>
                      <span class="phone-notif-time">21 maj</span>
                    </div>
                    <div class="phone-notif-title">Kom ihåg att lägga in din lön! 💰</div>
                    <div class="phone-notif-body">Lönen för maj 2025 är inte registrerad än.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- AI SECTION -->
    <section class="ai-section">
      <div class="container ai-inner">
        <div class="ai-text">
          <div class="section-tag">AI-analys</div>
          <h2>Din personliga ekonomirådgivare — alltid tillgänglig</h2>
          <p>
            Ordo analyserar er ekonomi och ger konkreta, personliga råd. Inte generiska tips från en blogg — utan insikter baserade på era faktiska siffror.
          </p>
          <ul class="ai-list">
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Identifierar om er sparkvot är hållbar
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Räntekänslighetsanalys på era bolån
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Konkreta förslag på optimeringar
            </li>
          </ul>
        </div>
        <div class="ai-card">
          <div class="ai-card-header">
            <div class="ai-score">
              <span class="ai-score-num">74</span>
              <span class="ai-score-label">/ 100</span>
            </div>
            <span class="ai-score-tag">Finansiell hälsa</span>
          </div>
          <div class="ai-card-body">
            <p>"Er sparkvot på 19 % är stabil. Med era bolån på 3,85 % snittränta skulle en räntehöjning på 1 pp kosta ca 2 460 kr mer per månad — er buffert klarar det med marginal, men amorteringstakten kan med fördel ökas något."</p>
          </div>
          <div class="ai-card-footer">
            <span>Genererad av Claude · Baserad på 12 månader</span>
          </div>
        </div>
      </div>
    </section>

    <!-- WAITLIST -->
    <section class="waitlist" id="waitlist">
      <div class="container waitlist-inner">
        <div class="section-tag light">Tidig tillgång</div>
        <h2>Ordo lanserar snart.</h2>
        <p>Lägg din e-postadress här så hör vi av oss när du kan börja använda Ordo.</p>
        <form class="waitlist-form" action="https://formspree.io/f/placeholder" method="POST">
          <input type="email" name="email" placeholder="din@email.se" required />
          <button type="submit">Anmäl intresse</button>
        </form>
        <p class="waitlist-note">Ingen spam. Ingen prenumeration. Bara ett meddelande när Ordo är redo.</p>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="container footer-inner">
        <a href="/" class="logo footer-logo">
          <svg viewBox="0 0 64 64" width="22" height="22" fill="none" aria-hidden="true" class="logo-icon">
            <rect x="9.75"  y="44" width="6.5" height="12" rx="3.25" fill="currentColor" opacity="0.45"/>
            <rect x="19.25" y="38" width="6.5" height="18" rx="3.25" fill="currentColor" opacity="0.60"/>
            <rect x="28.75" y="31" width="6.5" height="25" rx="3.25" fill="currentColor" opacity="0.75"/>
            <rect x="38.25" y="24" width="6.5" height="32" rx="3.25" fill="currentColor" opacity="0.90"/>
            <rect x="47.75" y="19" width="6.5" height="37" rx="3.25" fill="#a5b4fc"/>
          </svg>
          Ordo
        </a>
        <span class="footer-copy">© 2025 Ordo. Byggt i Sverige.</span>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --brand: #6366f1;
    --brand-dark: #4f46e5;
    --fg: #0f172a;
    --fg-2: #334155;
    --fg-3: #64748b;
    --fg-4: #94a3b8;
    --bg: #ffffff;
    --bg-2: #f8fafc;
    --bg-3: #f1f5f9;
    --border: #e2e8f0;
    --success: #10b981;
    --radius: 14px;
  }

  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', system-ui, sans-serif; color: var(--fg); background: var(--bg); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* NAV */
  nav { position: sticky; top: 0; z-index: 100; border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.88); backdrop-filter: blur(12px); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 60px; }
  .logo { font-weight: 700; font-size: 20px; letter-spacing: -0.03em; color: var(--fg); text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
  .logo-icon { color: var(--brand); flex-shrink: 0; }

  /* BUTTONS */
  .btn-primary { display: inline-flex; align-items: center; background: var(--brand); color: #fff; padding: 12px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; transition: background 0.15s, transform 0.1s; }
  .btn-primary:hover { background: var(--brand-dark); transform: translateY(-1px); }
  .btn-outline { display: inline-flex; align-items: center; border: 1px solid var(--border); color: var(--fg-2); padding: 8px 18px; border-radius: 8px; font-size: 14px; font-weight: 500; text-decoration: none; transition: border-color 0.15s, color 0.15s; }
  .btn-outline:hover { border-color: var(--brand); color: var(--brand); }
  .btn-ghost { display: inline-flex; align-items: center; color: var(--fg-3); font-size: 15px; font-weight: 500; text-decoration: none; transition: color 0.15s; }
  .btn-ghost:hover { color: var(--brand); }

  /* SECTION TAG */
  .section-tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); background: color-mix(in srgb, var(--brand) 10%, transparent); padding: 4px 10px; border-radius: 999px; margin-bottom: 16px; }
  .section-tag.light { color: #a5b4fc; background: rgba(255,255,255,0.12); }

  /* HERO */
  .hero { padding: 96px 0 80px; }
  .hero-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 24px; }
  .hero-badge { font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-3); background: var(--bg-3); border: 1px solid var(--border); padding: 5px 12px; border-radius: 999px; }
  h1 { font-size: clamp(40px, 6vw, 72px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; }
  h1 em { color: var(--brand); font-size: 1.05em; }
  .hero-sub { max-width: 520px; font-size: 18px; color: var(--fg-2); line-height: 1.65; }
  .hero-cta { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; justify-content: center; }

  /* MOCKUP — light app-style */
  .mockup { width: 100%; max-width: 740px; margin-top: 16px; border-radius: 16px; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 24px 64px rgba(0,0,0,0.10), 0 4px 16px rgba(0,0,0,0.06); }
  .mockup-bar { background: #f8fafc; border-bottom: 1px solid var(--border); padding: 10px 16px; display: flex; gap: 7px; align-items: center; }
