---
<!doctype html>
<html lang="sv" data-theme="light">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Användarvillkor — Ordo</title>
<meta name="description" content="Villkor för användning av Ordo."/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet"/>
<style>
:root{--font-ui:'Geist',ui-sans-serif,system-ui,sans-serif;--font-display:'Instrument Serif',Georgia,serif;--font-mono:'Geist Mono',ui-monospace,monospace;--brand-500:oklch(0.58 0.13 252);--logo-accent:oklch(0.60 0.13 55)}
[data-theme="light"],:root{--bg-page:oklch(0.978 0.005 80);--bg-surface:oklch(1 0 0);--bg-hover:oklch(0.95 0.005 90);--bg-ink:oklch(0.20 0.012 250);--fg-primary:oklch(0.20 0.012 250);--fg-secondary:oklch(0.40 0.010 250);--fg-tertiary:oklch(0.55 0.008 250);--fg-muted:oklch(0.68 0.008 250);--fg-on-ink:oklch(0.96 0.005 250);--border:oklch(0.90 0.006 250);--border-subtle:oklch(0.94 0.005 250);color-scheme:light}
[data-theme="dark"]{--bg-page:oklch(0.16 0.012 250);--bg-surface:oklch(0.22 0.012 250);--bg-hover:oklch(0.28 0.013 250);--bg-ink:oklch(0.96 0.005 250);--fg-primary:oklch(0.96 0.005 250);--fg-secondary:oklch(0.78 0.008 250);--fg-tertiary:oklch(0.58 0.010 250);--fg-muted:oklch(0.48 0.010 250);--fg-on-ink:oklch(0.20 0.012 250);--border:oklch(0.32 0.012 250);--border-subtle:oklch(0.26 0.012 250);color-scheme:dark}
*,*::before,*::after{box-sizing:border-box}html,body{margin:0;padding:0}
body{font-family:var(--font-ui);font-size:15px;line-height:1.6;color:var(--fg-primary);background:var(--bg-page);-webkit-font-smoothing:antialiased}
h1,h2,h3{margin:0;font-weight:400;letter-spacing:-0.015em}p,ul{margin:0}a{color:var(--brand-500);text-decoration:none}a:hover{text-decoration:underline}
.topbar{position:sticky;top:0;z-index:50;background:color-mix(in oklch,var(--bg-page) 82%,transparent);backdrop-filter:saturate(140%) blur(14px);border-bottom:1px solid var(--border-subtle)}
.topbar-inner{max-width:1200px;margin:0 auto;padding:16px 32px;display:flex;align-items:center;justify-content:space-between}
/* Logo pill-badge · Gradient·brand (§5c) */
.brand-pill{display:inline-flex;align-items:center;gap:10px;padding:10px 19px 10px 13px;background:linear-gradient(160deg,#5C7AE0 0%,#3D5BC7 55%,#2A3F9E 100%);border-radius:999px;color:#fff;text-decoration:none;box-shadow:0 8px 22px color-mix(in oklch,#3D5BC7 32%,transparent);flex-shrink:0}
.brand-pill-text{font-family:var(--font-display);font-size:30px;line-height:1;letter-spacing:-0.015em}
.theme-toggle{width:36px;height:36px;display:inline-flex;align-items:center;justify-content:center;background:transparent;border:1px solid var(--border);border-radius:999px;color:var(--fg-secondary);cursor:pointer}
.theme-toggle svg{width:16px;height:16px}
[data-theme="light"] .icon-sun{display:none}[data-theme="dark"] .icon-moon{display:none}
.page{max-width:720px;margin:0 auto;padding:64px 32px 96px}
.back{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--fg-tertiary);margin-bottom:48px;text-decoration:none}.back:hover{color:var(--fg-primary)}.back svg{width:14px;height:14px}
h1{font-family:var(--font-display);font-size:clamp(36px,6vw,56px);line-height:1.05;color:var(--fg-primary);margin-bottom:8px}
.updated{font-family:var(--font-mono);font-size:11px;letter-spacing:0.10em;text-transform:uppercase;color:var(--fg-muted);margin-bottom:48px}
.prose h2{font-family:var(--font-display);font-size:28px;margin-top:48px;margin-bottom:12px;color:var(--fg-primary)}
.prose p{color:var(--fg-secondary);line-height:1.65;margin-bottom:16px}
.prose ul{color:var(--fg-secondary);line-height:1.65;padding-left:20px;margin-bottom:16px;display:flex;flex-direction:column;gap:6px}
.prose li{padding-left:4px}.prose strong{color:var(--fg-primary);font-weight:500}
.footer-mini{max-width:1200px;margin:0 auto;padding:24px 32px;border-top:1px solid var(--border-subtle);display:flex;justify-content:space-between;align-items:center;font-family:var(--font-mono);font-size:11px;color:var(--fg-tertiary);letter-spacing:0.04em}
@media(max-width:600px){.page{padding:40px 20px 80px}.topbar-inner{padding:16px 20px}.footer-mini{padding:20px;flex-direction:column;gap:8px}}
</style>
</head>
<body>
<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="brand-pill" aria-label="Ordo">
      <svg width="24" height="24" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <rect x="10"   y="38" width="6.5" height="12" rx="3.25" fill="currentColor" opacity="0.50"/>
        <rect x="19.5" y="32" width="6.5" height="18" rx="3.25" fill="currentColor" opacity="0.65"/>
        <rect x="29"   y="25" width="6.5" height="25" rx="3.25" fill="currentColor" opacity="0.80"/>
        <rect x="38.5" y="18" width="6.5" height="32" rx="3.25" fill="currentColor"/>
        <rect x="48"   y="13" width="6.5" height="37" rx="3.25" fill="#FFD9A0"/>
      </svg>
      <span class="brand-pill-text">Ordo</span>
    </a>
    <button class="theme-toggle" id="themeToggle" aria-label="Växla tema" type="button">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/></svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
    </button>
  </div>
</header>

<main class="page">
  <a href="/" class="back">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    Tillbaka
  </a>
  <h1>Användarvillkor</h1>
  <p class="updated">Senast uppdaterad: 2026-05-23</p>

  <div class="prose">
    <h2>Tjänsten</h2>
    <p>Ordo är ett verktyg för att följa upp familjens ekonomi. Tjänsten tillhandahålls i befintligt skick under betaperioden. Vi förbehåller oss rätten att göra ändringar i tjänsten utan föregående meddelande.</p>

    <h2>Ditt konto</h2>
    <p>Du ansvarar för att hålla dina inloggningsuppgifter säkra. Du ansvarar för all aktivitet som sker via ditt konto.</p>

    <h2>Dina uppgifter</h2>
    <p>De ekonomiska uppgifter du lägger in i Ordo ägs av dig. Vi behandlar dem konfidentiellt och i enlighet med vår <a href="/integritetspolicy">integritetspolicy</a>. Vi säljer inte dina uppgifter.</p>

    <h2>Ansvarsbegränsning</h2>
    <p>Ordo är ett uppföljningsverktyg — inte ett rådgivningsverktyg. AI-analysen i appen ger generella observationer baserade på dina siffror, men ersätter inte professionell ekonomisk rådgivning. Vi tar inget ansvar för beslut fattade på basis av information i tjänsten.</p>

    <h2>Tillgänglighet</h2>
    <p>Vi strävar efter att hålla tjänsten tillgänglig men ger inga garantier om drifttid under betaperioden.</p>

    <h2>Kontakt</h2>
    <p>Frågor om villkoren? Skriv till <a href="mailto:hej@meetordo.se">hej@meetordo.se</a>.</p>
  </div>
</main>

<footer class="footer-mini">
  <span>ORDO · STOCKHOLM</span>
  <span>© 2026 ORDO</span>
</footer>

<script is:inline>
  (function() {
    var key = 'ordo-theme';
    var saved = localStorage.getItem(key);
    if (saved === 'dark' || saved === 'light') document.documentElement.setAttribute('data-theme', saved);
    var btn = document.getElementById('themeToggle');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem(key, next);
    });
  })();
</script>
</body>
</html>
